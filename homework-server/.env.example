# App
APP_NAME=homework-server
APP_ENV=production
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=homework
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=homework_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change_this_to_a_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# WeChat Mini Program
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret

# CORS
CORS_ORIGINS=*

# Rate Limit
RATE_LIMIT_PER_MINUTE=100
