<!--pages/points/points.wxml-->
<view class="container">
  <!-- 积分概况 -->
  <view class="stats-card">
    <view class="total-points">
      <text class="label">当前积分</text>
      <text class="num">{{stats.total_points || 0}}</text>
    </view>
    <view class="stats-row">
      <view class="stat-item">
        <text class="num">{{stats.today_points || 0}}</text>
        <text class="label">今日获得</text>
      </view>
      <view class="stat-item">
        <text class="num">{{stats.month_points || 0}}</text>
        <text class="label">本月获得</text>
      </view>
      <view class="stat-item">
        <text class="num">{{stats.total_earned || 0}}</text>
        <text class="label">累计获得</text>
      </view>
    </view>
  </view>

  <!-- 流水记录 -->
  <view class="section">
    <view class="section-title">积分流水</view>

    <block wx:if="{{logs.length > 0}}">
      <view class="log-item" wx:for="{{logs}}" wx:key="id">
        <view class="log-info">
          <text class="log-desc">{{item.description || '积分变动'}}</text>
          <text class="log-time">{{item.created_at}}</text>
        </view>
        <view class="log-amount {{item.amount > 0 ? 'earn' : 'spend'}}">
          {{item.amount > 0 ? '+' : ''}}{{item.amount}}
        </view>
      </view>
    </block>

    <view class="empty" wx:elif="{{!loading}}">
      <text>暂无流水记录</text>
    </view>

    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>
</view>
