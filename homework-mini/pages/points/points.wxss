/* pages/points/points.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.stats-card {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  padding: 40rpx;
  color: #fff;
}

.total-points {
  text-align: center;
  margin-bottom: 30rpx;
}

.total-points .label {
  font-size: 28rpx;
  opacity: 0.8;
}

.total-points .num {
  font-size: 80rpx;
  font-weight: bold;
  display: block;
  margin-top: 10rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-item .num {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.stat-item .label {
  font-size: 22rpx;
  opacity: 0.7;
}

.section {
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.log-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.log-info {
  flex: 1;
}

.log-desc {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.log-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.log-amount {
  font-size: 32rpx;
  font-weight: bold;
}

.log-amount.earn {
  color: #4caf50;
}

.log-amount.spend {
  color: #f44336;
}

.empty {
  text-align: center;
  padding: 80rpx;
  color: #999;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
}
