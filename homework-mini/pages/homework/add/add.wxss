.page {
  padding: 24rpx;
  padding-bottom: 60rpx;
}

.form-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.form-item__label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.required {
  color: #FF6B6B;
}

.form-item__input {
  width: 100%;
  height: 72rpx;
  border: 2rpx solid #EBEDF0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-item__textarea {
  width: 100%;
  min-height: 120rpx;
  border: 2rpx solid #EBEDF0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-item__picker {
  height: 72rpx;
  border: 2rpx solid #EBEDF0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.placeholder {
  color: #ccc;
}

.type-selector {
  display: flex;
  gap: 16rpx;
}

.type-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border: 2rpx solid #EBEDF0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.type-btn--active {
  border-color: #4A90D9;
  color: #4A90D9;
  background: #F0F5FF;
  font-weight: 600;
}

.weekday-selector {
  display: flex;
  gap: 12rpx;
}

.weekday-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border: 2rpx solid #EBEDF0;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.weekday-btn--active {
  border-color: #4A90D9;
  color: #fff;
  background: #4A90D9;
}

.date-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.date-cell {
  width: 80rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #EBEDF0;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.date-cell--active {
  border-color: #4A90D9;
  color: #fff;
  background: #4A90D9;
}

.submit-btn {
  margin-top: 40rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}
