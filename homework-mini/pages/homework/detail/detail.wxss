.page {
  padding-bottom: 140rpx;
}

.info-card {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.info-card__header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.info-card__name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-right: 16rpx;
}

.info-card__tag {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.info-card__desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
  display: block;
}

.info-card__meta {
  border-top: 1rpx solid #F0F0F0;
  padding-top: 20rpx;
}

.meta-item {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
}

.meta-item__label {
  font-size: 26rpx;
  color: #999;
}

.meta-item__value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.section {
  padding: 0 24rpx;
}

.section__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.record-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.record-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-item__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #52C41A;
  margin-top: 10rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.record-item__content {
  flex: 1;
}

.record-item__date {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.record-item__note {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.record-item__points {
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}
