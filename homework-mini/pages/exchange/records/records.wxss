.container {
  padding-bottom: 40rpx;
}

.record-item {
  margin-bottom: 0;
}

.record-name {
  font-size: 30rpx;
  color: #333;
}

.record-info {
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
  margin-top: 16rpx;
}

.tag-success {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-danger {
  background: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-pending {
  background: rgba(255, 169, 64, 0.1);
  color: #FFA940;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty-hint {
  text-align: center;
  line-height: 1.6;
}

/* 加载更多 */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
}

.loading-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #E8E8E8;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.no-more {
  text-align: center;
  padding: 30rpx;
}
