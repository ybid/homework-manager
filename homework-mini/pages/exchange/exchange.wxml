<view class="page">
  <!-- 顶部积分余额 -->
  <view class="balance-bar">
    <text class="balance-bar__label">当前积分</text>
    <text class="balance-bar__num">🏆 {{userPoints}}</text>
  </view>

  <!-- Tab 切换 -->
  <view class="tabs">
    <view class="tab-item {{currentTab === 0 ? 'tab-item--active' : ''}}" bindtap="switchTab" data-tab="0">
      奖品商城
    </view>
    <view class="tab-item {{currentTab === 1 ? 'tab-item--active' : ''}}" bindtap="switchTab" data-tab="1">
      兑换记录
    </view>
  </view>

  <!-- 奖品列表 -->
  <view wx:if="{{currentTab === 0}}">
    <loading show="{{loading}}" wx:if="{{loading}}" />

    <view class="reward-grid" wx:if="{{!loading && rewards.length > 0}}">
      <reward-card
        wx:for="{{rewards}}"
        wx:key="id"
        item="{{item}}"
        userPoints="{{userPoints}}"
        bind:tap="onRewardTap"
      />
    </view>

    <empty-state
      wx:if="{{!loading && rewards.length === 0}}"
      icon="🎁"
      text="暂无可兑换的奖品~"
    />
  </view>

  <!-- 兑换记录 -->
  <view wx:if="{{currentTab === 1}}">
    <view class="record-list" wx:if="{{records.length > 0}}">
      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <view class="record-item__left">
          <text class="record-item__name">{{item.reward_name}}</text>
          <text class="record-item__time">{{item.created_at}}</text>
        </view>
        <view class="record-item__right">
          <text class="record-item__points">-{{item.points}}</text>
          <text class="record-item__status">{{item.status === 'completed' ? '已完成' : '处理中'}}</text>
        </view>
      </view>
    </view>

    <loading show="{{recordLoading}}" wx:if="{{recordLoading}}" />

    <empty-state
      wx:if="{{!recordLoading && records.length === 0}}"
      icon="📦"
      text="还没有兑换记录~"
    />
  </view>

  <!-- 兑换确认弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal">
    <view class="modal" catchtap="">
      <view class="modal__title">确认兑换</view>
      <view class="modal__body">
        <text class="modal__reward-name">{{selectedReward.name}}</text>
        <text class="modal__cost">消耗 {{selectedReward.points}} 积分</text>
        <text class="modal__balance">兑换后剩余: {{userPoints - selectedReward.points}} 积分</text>
      </view>
      <view class="modal__footer">
        <button class="modal__btn modal__btn--cancel" bindtap="closeModal">取消</button>
        <button class="modal__btn modal__btn--confirm" bindtap="confirmExchange">确认兑换</button>
      </view>
    </view>
  </view>

  <!-- 兑换成功动画 -->
  <view class="success-overlay" wx:if="{{showSuccess}}">
    <view class="success-content success-anim">
      <text class="success-icon">🎉</text>
      <text class="success-text">兑换成功！</text>
      <text class="success-sub">{{successMsg}}</text>
    </view>
  </view>
</view>
