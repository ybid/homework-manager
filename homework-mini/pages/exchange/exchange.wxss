.balance-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #FFA940, #FF8C00);
  margin: 24rpx;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(255, 169, 64, 0.3);
}

.balance-bar__label {
  font-size: 26rpx;
  opacity: 0.9;
}

.balance-bar__num {
  font-size: 40rpx;
  font-weight: 700;
}

.tabs {
  display: flex;
  margin: 0 24rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item--active {
  color: #4A90D9;
  font-weight: 600;
}

.tab-item--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  width: 40%;
  height: 4rpx;
  background: #4A90D9;
  border-radius: 2rpx;
}

.reward-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 24rpx;
}

.record-list {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-item__left {
  flex: 1;
}

.record-item__name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.record-item__time {
  font-size: 22rpx;
  color: #bbb;
  display: block;
  margin-top: 6rpx;
}

.record-item__right {
  text-align: right;
}

.record-item__points {
  font-size: 30rpx;
  color: #FF6B6B;
  font-weight: 600;
  display: block;
}

.record-item__status {
  font-size: 22rpx;
  color: #52C41A;
  display: block;
  margin-top: 4rpx;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal {
  width: 580rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal__title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.modal__body {
  padding: 36rpx 30rpx;
  text-align: center;
}

.modal__reward-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.modal__cost {
  font-size: 28rpx;
  color: #FFA940;
  display: block;
  margin-bottom: 10rpx;
}

.modal__balance {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.modal__footer {
  display: flex;
  border-top: 1rpx solid #F5F5F5;
}

.modal__btn {
  flex: 1;
  text-align: center;
  padding: 26rpx 0;
  font-size: 30rpx;
  background: none;
  border: none;
  border-radius: 0;
  line-height: 1.4;
}

.modal__btn::after {
  border: none;
}

.modal__btn--cancel {
  color: #999;
  border-right: 1rpx solid #F5F5F5;
}

.modal__btn--confirm {
  color: #4A90D9;
  font-weight: 600;
}

/* Success overlay */
.success-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.success-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx;
  text-align: center;
}

.success-icon {
  font-size: 100rpx;
  display: block;
}

.success-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #52C41A;
  display: block;
  margin-top: 20rpx;
}

.success-sub {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-top: 10rpx;
}

@keyframes successPop {
  0% { transform: scale(0.5); opacity: 0; }
  60% { transform: scale(1.1); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

.success-anim {
  animation: successPop 0.5s ease-out forwards;
}
