.month-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #fff;
}

.month-nav__btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #4A90D9;
  border-radius: 50%;
}

.month-nav__btn:active {
  background: #F0F5FF;
}

.month-nav__title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin: 0 30rpx;
  min-width: 200rpx;
  text-align: center;
}

.weekday-header {
  display: flex;
  background: #fff;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.weekday-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 10rpx 0;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  padding: 8rpx;
}

.day-cell {
  width: calc(100% / 7);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  min-height: 100rpx;
  position: relative;
  box-sizing: border-box;
}

.day-cell--empty {
  min-height: auto;
}

.day-cell__num {
  font-size: 28rpx;
  color: #333;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.day-cell--today .day-cell__num {
  background: #4A90D9;
  color: #fff;
}

.day-cell--selected {
  background: #F0F5FF;
  border-radius: 12rpx;
}

.day-cell__dots {
  margin-top: 4rpx;
}

.day-cell__dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.day-cell__dot--done {
  background: #52C41A;
}

.day-cell__dot--partial {
  background: #FFA940;
}

.day-cell__count {
  font-size: 16rpx;
  color: #999;
  margin-top: 2rpx;
}

.day-detail {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.day-detail__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.day-detail__count {
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
}

.detail-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-item__status {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #ccc;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.detail-item__status--done {
  background: #52C41A;
  border-color: #52C41A;
  color: #fff;
}

.detail-item__name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.detail-item__points {
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
}
