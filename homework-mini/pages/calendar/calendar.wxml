<view class="page">
  <!-- 月份切换 -->
  <view class="month-nav">
    <view class="month-nav__btn" bindtap="prevMonth">‹</view>
    <text class="month-nav__title">{{year}}年{{month}}月</text>
    <view class="month-nav__btn" bindtap="nextMonth">›</view>
  </view>

  <!-- 星期表头 -->
  <view class="weekday-header">
    <view class="weekday-cell" wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this">{{item}}</view>
  </view>

  <!-- 日历网格 -->
  <view class="calendar-grid">
    <!-- 空白占位 -->
    <view class="day-cell day-cell--empty" wx:for="{{emptyDays}}" wx:key="*this"></view>

    <!-- 日期单元格 -->
    <view
      wx:for="{{calendarDays}}"
      wx:key="date"
      class="day-cell {{item.date === selectedDate ? 'day-cell--selected' : ''}} {{item.isToday ? 'day-cell--today' : ''}}"
      bindtap="selectDay"
      data-date="{{item.date}}"
    >
      <text class="day-cell__num">{{item.day}}</text>
      <view class="day-cell__dots" wx:if="{{item.total > 0}}">
        <view class="day-cell__dot {{item.completed >= item.total ? 'day-cell__dot--done' : 'day-cell__dot--partial'}}"></view>
      </view>
      <text class="day-cell__count" wx:if="{{item.total > 0}}">{{item.completed}}/{{item.total}}</text>
    </view>
  </view>

  <!-- 选中日期的作业详情 -->
  <view class="day-detail" wx:if="{{selectedDate && selectedDayData}}">
    <view class="day-detail__title">
      {{selectedDate}} 的作业
      <text class="day-detail__count">（{{selectedDayData.completed}}/{{selectedDayData.total}}）</text>
    </view>

    <view class="day-detail__list" wx:if="{{selectedDayData.list && selectedDayData.list.length > 0}}">
      <view class="detail-item" wx:for="{{selectedDayData.list}}" wx:key="id">
        <view class="detail-item__status {{item.completed ? 'detail-item__status--done' : ''}}">
          {{item.completed ? '✓' : '○'}}
        </view>
        <text class="detail-item__name">{{item.name}}</text>
        <text class="detail-item__points text-warning">+{{item.points}}</text>
      </view>
    </view>

    <empty-state
      wx:if="{{!selectedDayData.list || selectedDayData.list.length === 0}}"
      icon="📅"
      text="这天没有作业安排~"
    />
  </view>
</view>
