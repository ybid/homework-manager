.container {
  padding-bottom: 60rpx;
}

.header {
  padding: 50rpx 40rpx 30rpx;
  text-align: center;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 12rpx;
}

.stat-card {
  width: calc(50% - 36rpx);
  margin: 10rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 20rpx;
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 20rpx;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  text-align: center;
}

/* 加载 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E8E8E8;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
