.container {
  padding-bottom: 40rpx;
}

.header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.menu-list {
  padding: 0 8rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
}

.menu-item:active {
  opacity: 0.85;
}

.menu-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: rgba(74, 144, 217, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-title {
  font-size: 30rpx;
  color: #333;
}

.menu-desc {
  line-height: 1.5;
}

.menu-arrow {
  font-size: 40rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}
