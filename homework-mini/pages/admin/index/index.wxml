<view class="container">
  <view class="header">
    <view class="header-title">管理后台</view>
    <view class="header-desc text-sm text-gray">选择功能模块进行管理</view>
  </view>

  <view class="menu-list">
    <view class="card menu-item" wx:for="{{menus}}" wx:key="title" bindtap="onMenuTap" data-path="{{item.path}}">
      <view class="menu-icon">{{item.icon}}</view>
      <view class="menu-content flex-1">
        <view class="menu-title text-bold">{{item.title}}</view>
        <view class="menu-desc text-sm text-gray mt-10">{{item.desc}}</view>
      </view>
      <view class="menu-arrow text-gray">›</view>
    </view>
  </view>
</view>
