.container {
  padding-bottom: 40rpx;
}

.user-item {
  margin-bottom: 0;
}

.user-item:active {
  opacity: 0.85;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #E8E8E8;
  flex-shrink: 0;
}

.user-name {
  font-size: 30rpx;
  color: #333;
}

.tag-admin {
  background: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-normal {
  background: rgba(153, 153, 153, 0.1);
  color: #999;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

/* 加载 */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
}

.loading-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #E8E8E8;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.no-more {
  text-align: center;
  padding: 30rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.modal-dialog {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  z-index: 201;
}

.modal-title {
  font-size: 34rpx;
  text-align: center;
  color: #333;
}

.modal-user {
  text-align: center;
  margin-top: 8rpx;
}

.modal-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.modal-input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-actions {
  justify-content: space-between;
}
