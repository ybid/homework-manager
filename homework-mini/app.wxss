/* app.wxss */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 全局样式 */
view {
  box-sizing: border-box;
}

/* 清除默认样式 */
button {
  margin: 0;
  padding: 0;
  background-color: transparent;
  border-radius: 0;
  line-height: normal;
}

button::after {
  border: none;
}

input {
  box-sizing: border-box;
}

/* 公共工具类 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-center {
  text-align: center;
}

.text-primary {
  color: #4A90D9;
}

.text-success {
  color: #4caf50;
}

.text-warning {
  color: #ff9800;
}

.text-danger {
  color: #f44336;
}
