.hw-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.hw-card--done {
  opacity: 0.75;
}

.hw-card__left {
  margin-right: 20rpx;
}

.hw-card__status {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #ccc;
}

.hw-card__status--done {
  border-color: #52C41A;
  background: #52C41A;
  color: #fff;
}

.hw-card__content {
  flex: 1;
  min-width: 0;
}

.hw-card__header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.hw-card__name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-right: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 300rpx;
}

.hw-card__name--done {
  text-decoration: line-through;
  color: #999;
}

.hw-card__tag {
  display: inline-flex;
  align-items: center;
  padding: 2rpx 14rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.hw-card__info {
  display: flex;
  align-items: center;
}

.hw-card__points {
  font-size: 24rpx;
  color: #FFA940;
  margin-right: 20rpx;
}

.hw-card__time {
  font-size: 22rpx;
  color: #bbb;
}

.hw-card__right {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.hw-card__action-wrap {
  position: relative;
}

.hw-card__btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  padding: 0;
  margin: 0;
  line-height: 60rpx;
  border: none;
}

.hw-card__btn::after {
  border: none;
}

.hw-card__btn:active {
  opacity: 0.85;
}

.hw-card__done-text {
  font-size: 24rpx;
  color: #52C41A;
  font-weight: 500;
}

@keyframes pointsFlyIn {
  0% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  60% {
    opacity: 1;
    transform: translateY(-60rpx) scale(1.3);
  }
  100% {
    opacity: 0;
    transform: translateY(-120rpx) scale(0.8);
  }
}

.points-anim {
  animation: pointsFlyIn 1.2s ease-out forwards;
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 700;
  color: #FFA940;
  pointer-events: none;
  white-space: nowrap;
}
